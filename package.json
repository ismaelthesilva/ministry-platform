{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:all": "concurrently \"npm run dev:next\" \"npm run dev:test\"",
    "dev:full": "concurrently \"npm run dev:next\" \"npm run dev:studio\" \"npm run dev:test\"",
    "dev:next": "next dev",
    "dev:studio": "npx prisma studio",
    "dev:test": "concurrently -n next,test \"next dev\" \"vitest\"",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint:check": "prettier --check .",
    "lint:fix": "prettier --write .",
    "lint": "npm run lint:check && npm run lint:fix",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:bench": "vitest bench tests/performance/",
    "test:perf": "vitest bench tests/performance/ --reporter=verbose",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:migrate-exercises": "tsx scripts/migrate-exercises-to-db.ts",
    "db:validate-exercises": "tsx scripts/validate-exercise-standardization.ts",
    "lint:eslint:check": "eslint .",
    "prepare": "husky",
    "commit": "cz"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@emailjs/browser": "^4.4.1",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@simplewebauthn/browser": "^9.0.1",
    "@simplewebauthn/server": "^9.0.3",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "lucide-react": "^0.555.0",
    "next": "^16.0.10",
    "next-auth": "^5.0.0-beta.30",
    "prisma": "^7.3.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "resend": "^6.9.3",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.2.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.27",
    "commitizen": "4.3.1",
    "concurrently": "9.2.1",
    "cz-conventional-changelog": "3.3.0",
    "dotenv": "^17.2.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jest": "^29.15.0",
    "husky": "9.1.7",
    "i": "0.3.7",
    "jsdom": "^28.0.0",
    "npm": "11.12.0",
    "prettier": "^2.8.8",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}

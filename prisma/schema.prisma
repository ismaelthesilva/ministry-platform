generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// NextAuth User model
model User {
  id                String    @id @default(cuid())
  name              String?   // Full name (kept for backwards compatibility with NextAuth)
  firstName         String?
  lastName          String?
  email             String?   @unique
  emailVerified     DateTime?
  image             String?
  password          String?
  
  // Bible Tracker fields
  country           String?
  phone             String?
  gender            String?   // "male", "female", or custom
  religion          String?
  age               Int?
  favBook           String?   // Favorite Bible book
  favVerse          String?   // Favorite Bible verse
  selectedPlanId    String?
  preferredLanguage String    @default("pt") // "pt" or "en"
  
  // Relations
  accounts          Account[]
  sessions          Session[]
  progress          UserProgress[]
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Plan {
  id          String         @id @default(cuid())
  slug        String         // 'bible-only', 'prophetic', 'classical'
  title       String
  description String?
  language    String         @default("pt") // "pt" or "en"
  readings    DailyReading[]
  
  @@unique([slug, language])
  @@index([language])
}

model DailyReading {
  id          String   @id @default(cuid())
  planId      String
  plan        Plan     @relation(fields: [planId], references: [id])
  
  dayNumber   Int      // 1 a 365
  dateDisplay String   // ex: "1 de Janeiro"
  
  // Conteúdo Unificado
  bibleTextMain    String?  // O texto principal (História) - opcional para algumas leituras
  bibleTextDevo    String?  // Texto devocional (Salmos/Sabedoria - usado no plano Profético)
  
  // Campos de Comentário (EGW ou Clássicos)
  commentaryAuthor String?  // "Ellen G. White" ou "Santo Agostinho"
  commentaryWork   String?  // "Patriarcas e Profetas" ou "Confissões"
  commentaryRef    String?  // Capítulo ou Referência
  topic            String?  // Tema do dia
  language         String   @default("pt") // "pt" or "en"

  progress    UserProgress[]

  @@unique([planId, dayNumber], name: "planId_dayNumber")
  @@index([planId, dayNumber])
}

model UserProgress {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  readingId String
  reading   DailyReading @relation(fields: [readingId], references: [id])

  completedAt DateTime @default(now())

  @@unique([userId, readingId])
}
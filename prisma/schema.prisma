generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// NextAuth User model
model User {
  id                String    @id @default(cuid())
  name              String?   // Full name (kept for backwards compatibility with NextAuth)
  firstName         String?
  lastName          String?
  email             String?   @unique
  emailVerified     DateTime?
  image             String?
  password          String?
  
  // Bible Tracker fields
  country           String?
  phone             String?
  gender            String?   // "male", "female", or custom
  religion          String?
  age               Int?
  favBook           String?   // Favorite Bible book
  favVerse          String?   // Favorite Bible verse
  selectedPlanId    String?
  preferredLanguage String    @default("pt") // "pt" or "en"
  
  // Relations
  accounts          Account[]
  sessions          Session[]
  progress          UserProgress[]
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Plan {
  id          String         @id @default(cuid())
  slug        String         // 'bible', 'prophetic', 'classic'
  title       String
  description String?
  language    String         @default("en") // "en" or "br"
  readings    DailyReading[]
  
  @@unique([slug, language])
  @@index([language])
}

model DailyReading {
  id        String   @id @default(cuid())
  planId    String
  plan      Plan     @relation(fields: [planId], references: [id])

  dayNumber Int      // 1-365
  date      String   // e.g. "01-Jan"

  // Bible reading (all plans)
  bible     String?  // e.g. "Genesis 1-3"

  // Commentary fields (prophetic + classic only)
  author    String?  // "Ellen G. White" or "Saint Augustine"
  book      String?  // "Patriarchs and Prophets" or "Confessions"
  title     String?  // Chapter title or key theme

  progress  UserProgress[]

  @@unique([planId, dayNumber], name: "planId_dayNumber")
  @@index([planId, dayNumber])
}

model UserProgress {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  readingId String
  reading   DailyReading @relation(fields: [readingId], references: [id])

  completedAt DateTime @default(now())

  @@unique([userId, readingId])
}